{
  "name": "@mmaappss/sync",
  "version": "0.1.0-beta.1",
  "description": "(Beta) Define once and share rules, commands, skills, and agent plugins across teams and coding agents, with minimal config and powerful options when needed.",
  "type": "module",
  "license": "Unlicense",
  "repository": "github:flycrum/mmaappss",
  "homepage": "https://github.com/flycrum/mmaappss#readme",
  "bugs": {
    "url": "https://github.com/flycrum/mmaappss/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mmaappss-sync": "./bin/mmaappss-sync.mjs"
  },
  "files": [
    "scripts",
    ".agents",
    "bin"
  ],
  "scripts": {
    "lint": "eslint .",
    "mmaappss:sync:clear:all": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-clear-all.ts",
    "mmaappss:sync:clear:all:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-clear-integration-test.ts all",
    "mmaappss:sync:all": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-all.ts",
    "mmaappss:sync:all:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-integration-test.ts all",
    "mmaappss:sync:claude:clear": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-claude-clear.ts",
    "mmaappss:sync:claude:clear:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-clear-integration-test.ts claude",
    "mmaappss:sync:claude:sync": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-claude-sync.ts",
    "mmaappss:sync:claude:sync:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-integration-test.ts claude",
    "mmaappss:sync:codex:clear": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-codex-clear.ts",
    "mmaappss:sync:codex:clear:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-clear-integration-test.ts codex",
    "mmaappss:sync:codex:sync": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-codex-sync.ts",
    "mmaappss:sync:codex:sync:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-integration-test.ts codex",
    "mmaappss:sync:cursor:clear": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-cursor-clear.ts",
    "mmaappss:sync:cursor:clear:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-clear-integration-test.ts cursor",
    "mmaappss:sync:cursor:sync": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-sync-cursor-sync.ts",
    "mmaappss:sync:cursor:sync:test": "tsx .agents/plugins/mmaappss-sync/scripts/integration-test/mmaappss-sync-integration-test.ts cursor",
    "mmaappss:post-merge": "tsx .agents/plugins/mmaappss-sync/scripts/mmaappss-post-merge.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "lodash-es": "^4.17.21",
    "minimatch": "^10.0.0",
    "neverthrow": "^7.2.0",
    "pino": "^9.6.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@mmaappss/eslint-config": "workspace:*",
    "@mmaappss/typescript-config": "workspace:*",
    "@mmaappss/vitest-config": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.15.0",
    "fast-json-patch": "^3.1.1",
    "globals": "^15.12.0",
    "tsx": "^4.19.0",
    "type-fest": "^5.4.4",
    "typescript": "5.9.3",
    "vitest": "^3.0.0"
  }
}
