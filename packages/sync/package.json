{
  "name": "@mmaappss/sync",
  "version": "0.1.0-beta.1",
  "description": "(Beta) Define once and share rules, commands, skills, and agent plugins across teams and coding agents, with minimal config and powerful options when needed.",
  "type": "module",
  "license": "Unlicense",
  "repository": "github:flycrum/mmaappss",
  "homepage": "https://github.com/flycrum/mmaappss#readme",
  "bugs": {
    "url": "https://github.com/flycrum/mmaappss/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mmaappss-sync": "./bin/mmaappss-sync.mjs"
  },
  "exports": {
    "./config": "./config/index.ts",
    "./sync-manifest": "./scripts/common/sync-manifest.ts"
  },
  "files": [
    "scripts",
    ".agents",
    "bin",
    "getting-started",
    "config"
  ],
  "scripts": {
    "lint": "eslint .",
    "mmaappss:post-merge": "tsx scripts/mmaappss-post-merge.ts",
    "mmaappss:sync": "tsx scripts/mmaappss-sync-all.ts",
    "mmaappss:sync:clear": "tsx scripts/mmaappss-sync-clear-all.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "fast-json-patch": "^3.1.1",
    "fs-extra": "^11.2.0",
    "lodash-es": "^4.17.21",
    "minimatch": "^10.0.0",
    "neverthrow": "^7.2.0",
    "pino": "^9.6.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@mmaappss/eslint-config": "workspace:*",
    "@mmaappss/typescript-config": "workspace:*",
    "@mmaappss/vitest-config": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.15.0",
    "fast-json-patch": "^3.1.1",
    "globals": "^15.12.0",
    "tsx": "^4.19.0",
    "type-fest": "^5.4.4",
    "typescript": "5.9.3",
    "vitest": "^3.0.0"
  }
}
