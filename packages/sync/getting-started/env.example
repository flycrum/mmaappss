# mmaappss sync — minimal env example
# Copy to .env at repo root. Env overrides mmaappss.config.ts when set.

# Enable Claude, Cursor, Codex marketplaces (default: true when unset)
MMAAPPSS_MARKETPLACE_CLAUDE=true
MMAAPPSS_MARKETPLACE_CURSOR=true
MMAAPPSS_MARKETPLACE_CODEX=true

# Optional: file logging for debugging (default: false)
# MMAAPPSS_LOGGING_ENABLED=true
