{
  "claude": {
    "agentsMdSymlink": {
      "options": {
        "sourceFile": "AGENTS.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# mmaappss: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": [
        "CLAUDE.md",
        "packages/app/CLAUDE.md"
      ]
    },
    "skillsDirectorySync": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"]
    },
    "localMarketplaceSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "mmaappss-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "plugins": [
          {
            "name": "nested",
            "source": "./packages/app/.agents/plugins/nested",
            "description": "Fake nested plugin under packages/app for integration test sandbox.",
            "version": "0.1.0"
          },
          {
            "name": "root",
            "source": "./.agents/plugins/root",
            "description": "Fake root plugin for integration test sandbox.",
            "version": "0.1.0"
          }
        ]
      }
    },
    "settingsSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "mmaappss-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "testagent": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "legacyHeadingsToRemove": [
          "Codex Marketplace"
        ],
        "removeExistingSectionBlocks": true,
        "sectionHeading": "packages (generated by mmaappss)"
      }
    }
  }
}
