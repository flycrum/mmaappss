{
  "claude": {
    "agentsMdSymlink": {
      "options": {
        "sourceFile": "AGENTS.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# mmaappss: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md"]
    },
    "localMarketplaceSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "mmaappss-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "plugins": [
          {
            "name": "root",
            "source": "./.agents/plugins/root",
            "description": "Fake root plugin for integration test sandbox.",
            "version": "0.1.0"
          }
        ]
      }
    },
    "rulesSymlink": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.mmaappss-claude-sync.json"
      },
      "symlinks": [".claude/rules/root/root-rule.md"]
    },
    "skillsDirectorySync": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"]
    },
    "settingsSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "mmaappss-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "localPluginsContentSync": {
      "options": {
        "customHandler": {},
        "requiredManifestKey": "cursor",
        "targetRoot": ".cursor"
      },
      "symlinks": [
        ".cursor/commands/root/root-hello.md"
      ],
      "fsAutoRemoval": [".cursor/rules/root/root-rule.mdc"]
    }
  },
  "codex": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "legacyHeadingsToRemove": ["Codex Marketplace"],
        "removeExistingSectionBlocks": true,
        "sectionHeading": "packages (generated by mmaappss)"
      }
    }
  },
  "testagent": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "legacyHeadingsToRemove": [
          "Codex Marketplace"
        ],
        "removeExistingSectionBlocks": true,
        "sectionHeading": "packages (generated by mmaappss)"
      }
    }
  }
}
