{
  "claude": {
    "agentsMdSymlink": {
      "options": {
        "sourceFile": "AGENTS.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# mmaappss: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md"]
    },
    "local2MarketplaceSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "mmaappss-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "plugins": [
          {
            "name": "getting-started",
            "source": "./packages/sync/getting-started/.agents/plugins/getting-started",
            "description": "Skills for first-time setup, local testing, doctor, updates, and removal of @mmaappss/sync in consumer projects.",
            "version": "0.1.0"
          },
          {
            "name": "git",
            "source": "./.agents/plugins/git",
            "description": "Git workflow commands for AI agents: commit staged files, craft message, push with guards.",
            "version": "0.1.0"
          },
          {
            "name": "mmaappss",
            "source": "./packages/sync/.agents/plugins/mmaappss-sync",
            "description": "Driver plugin: sync local marketplaces and plugins for Claude, Cursor, and Codex; rules, skills, and scripts to run, enforce, and audit the system.",
            "version": "0.1.0"
          },
          {
            "name": "npm-release",
            "source": "./packages/sync/.agents/plugins/npm-release",
            "description": "Rules and skills for publishing @mmaappss/sync to npm: version bump, dist-tag, and release steps. No release tool; npm version + npm publish only.",
            "version": "0.1.0"
          },
          {
            "name": "pino-logger",
            "source": "./packages/sync/.agents/plugins/pino-logger",
            "description": "Pino logging strategy, rules, and skills for debugging mmaappss sync and tooling.",
            "version": "0.1.0"
          }
        ]
      }
    },
    "rulesSymlink": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.mmaappss-claude-sync.json"
      },
      "symlinks": [
        ".claude/rules/git/git-no-commit-from-inferred-intent.md",
        ".claude/rules/mmaappss-sync/mmaappss-file-naming.md",
        ".claude/rules/mmaappss-sync/mmaappss-rules-purpose-and-guidelines.md",
        ".claude/rules/mmaappss-sync/mmaappss-writing-rules-commands-skills.md",
        ".claude/rules/npm-release/npm-release-publish-steps.md",
        ".claude/rules/npm-release/npm-release-versioning.md",
        ".claude/rules/pino-logger/pino-logger-logging.md"
      ]
    },
    "settingsSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "mmaappss-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "localPluginsContentSync": {
      "options": {
        "customHandler": {},
        "requiredManifestKey": "cursor",
        "targetRoot": ".cursor"
      },
      "symlinks": [
        ".cursor/commands/git/git-commit-staged-files.md",
        ".cursor/commands/pino-logger/pino-logger-tail-log.md",
        ".cursor/skills/mmaappss-sync/mmaappss-add-new-plugin",
        ".cursor/skills/mmaappss-sync/run-marketplace-sync",
        ".cursor/skills/npm-release/npm-release-deploy-wizard",
        ".cursor/skills/pino-logger/debug-pino-logger",
        ".cursor/skills/getting-started/getting-started-doctor",
        ".cursor/skills/getting-started/getting-started-remove-mmaappss-sync",
        ".cursor/skills/getting-started/getting-started-setup-from-npm",
        ".cursor/skills/getting-started/getting-started-setup-local-testing",
        ".cursor/skills/getting-started/getting-started-updates"
      ],
      "fsAutoRemoval": [
        ".cursor/rules/git/git-no-commit-from-inferred-intent.mdc",
        ".cursor/rules/mmaappss-sync/mmaappss-file-naming.mdc",
        ".cursor/rules/mmaappss-sync/mmaappss-rules-purpose-and-guidelines.mdc",
        ".cursor/rules/mmaappss-sync/mmaappss-writing-rules-commands-skills.mdc",
        ".cursor/rules/npm-release/npm-release-publish-steps.mdc",
        ".cursor/rules/npm-release/npm-release-versioning.mdc",
        ".cursor/rules/pino-logger/pino-logger-logging.mdc"
      ]
    }
  },
  "codex": {
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "legacyHeadingsToRemove": ["Codex Marketplace"],
        "removeExistingSectionBlocks": true,
        "sectionHeading": "packages (generated by mmaappss)"
      }
    }
  },
  "testagent": {
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "legacyHeadingsToRemove": ["Codex Marketplace"],
        "removeExistingSectionBlocks": true,
        "sectionHeading": "packages (generated by mmaappss)"
      }
    }
  }
}
