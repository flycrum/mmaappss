{
  "name": "mmaappss",
  "description": "Monorepo for shared configs and scripts to unify rules, commands, skills, and agent plugins across coding tools.",
  "private": true,
  "type": "module",
  "license": "Unlicense",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "mmaappss:sync:clear:all": "pnpm -F @mmaappss/sync run mmaappss:sync:clear:all",
    "mmaappss:sync:all": "pnpm -F @mmaappss/sync run mmaappss:sync:all",
    "mmaappss:sync:all:test": "pnpm -F @mmaappss/sync run mmaappss:sync:all:test",
    "mmaappss:sync:claude:clear": "pnpm -F @mmaappss/sync run mmaappss:sync:claude:clear",
    "mmaappss:sync:claude:sync": "pnpm -F @mmaappss/sync run mmaappss:sync:claude:sync",
    "mmaappss:sync:claude:sync:test": "pnpm -F @mmaappss/sync run mmaappss:sync:claude:sync:test",
    "mmaappss:sync:codex:clear": "pnpm -F @mmaappss/sync run mmaappss:sync:codex:clear",
    "mmaappss:sync:codex:sync": "pnpm -F @mmaappss/sync run mmaappss:sync:codex:sync",
    "mmaappss:sync:codex:sync:test": "pnpm -F @mmaappss/sync run mmaappss:sync:codex:sync:test",
    "mmaappss:sync:cursor:clear": "pnpm -F @mmaappss/sync run mmaappss:sync:cursor:clear",
    "mmaappss:sync:cursor:sync": "pnpm -F @mmaappss/sync run mmaappss:sync:cursor:sync",
    "mmaappss:sync:cursor:sync:test": "pnpm -F @mmaappss/sync run mmaappss:sync:cursor:sync:test",
    "test": "turbo run test",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@mmaappss/eslint-config": "workspace:*",
    "@mmaappss/prettier-config": "workspace:*",
    "@mmaappss/typescript-config": "workspace:*",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.0",
    "typescript": "5.9.3",
    "tsx": "^4.19.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
