# Dependencies
node_modules/

# Build outputs
dist/

# Turbo cache (root and per-package)
**/.turbo/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.log

# mmaappss file logging (when loggingEnabled: true)
.mmaappss/

# Ignore root-level Claude and Cursor plugin dirs (sync scripts; do not commit)
# Note: plugin dirs under .agents/ (e.g. .agents/plugins/*/.claude-plugin/) remain tracked (as required by the mmaappss system definitions for their plugins)
/.claude-plugin/
/.cursor-plugin/
# Recursively ingore these (not required by the mmaappss system definitions for their plugins)
.claude/
.cursor/
# mmaappss: symlinked from AGENTS.md for Claude (when Claude marketplace sync is enabled)
CLAUDE.md
# mmaappss: Codex marketplace section (generated by mmaappss sync)
AGENTS.override.md
# Root-level mmaappss config (optional; copy from mmaappss.config.example.ts)
mmaappss.config.ts
